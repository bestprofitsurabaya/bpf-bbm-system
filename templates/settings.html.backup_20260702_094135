    <script>
        // ============================================================
        // ADMIN PIN GATE
        // ============================================================
        async function verifyAdminPin() {
            var pin = document.getElementById('adminPinInput').value;
            var errorEl = document.getElementById('adminPinError');
            
            if (pin.length !== 6 || !/^\d{6}$/.test(pin)) {
                errorEl.textContent = 'PIN harus 6 digit angka';
                errorEl.style.display = 'block';
                return;
            }
            
            errorEl.style.display = 'none';
            
            try {
                var res = await fetch('/api/verify-pin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: 'admin', pin: pin })
                });
                var data = await res.json();
                
                if (data.status === 'success') {
                    // Tampilkan konten
                    document.getElementById('settingsGate').style.display = 'none';
                    document.getElementById('settingsContent').style.display = 'block';
                    // Trigger load tabel
                    if (typeof loadDriverTable === 'function') loadDriverTable();
                    if (typeof loadUserTable === 'function') loadUserTable();
                } else {
                    errorEl.textContent = 'PIN salah! Akses ditolak.';
                    errorEl.style.display = 'block';
                    document.getElementById('adminPinInput').value = '';
                    document.getElementById('adminPinInput').focus();
                }
            } catch(e) {
                errorEl.textContent = 'Error koneksi';
                errorEl.style.display = 'block';
            }
        }
        
        document.getElementById('adminPinInput').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') verifyAdminPin();
        });
    </script>


